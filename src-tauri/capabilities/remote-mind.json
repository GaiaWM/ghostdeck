{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "remote-mind",
  "description": "Let the gateway's owner page (loaded remotely) run a ghost's mind on LOCAL llm endpoints. The http scope is localhost-only: the page cannot use the app to reach anything else.",
  "windows": ["main"],
  "remote": {
    "urls": [
      "https://svc.ingmmo.com",
      "https://svc.ingmmo.com/*",
      "http://localhost:*",
      "http://localhost:*/*",
      "http://127.0.0.1:*",
      "http://127.0.0.1:*/*"
    ]
  },
  "permissions": [
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://localhost:*/*" },
        { "url": "http://127.0.0.1:*/*" }
      ]
    }
  ]
}
