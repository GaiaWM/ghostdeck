{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GhostDeck",
  "version": "0.2.2",
  "identifier": "org.gaiawm.ghostdeck",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "GhostDeck — your ghosts",
        "width": 1180,
        "height": 780,
        "minWidth": 720,
        "minHeight": 520,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico", "icons/icon.icns"]
  }
}
